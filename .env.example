# Copy this file to .env and fill in your values.
# Get API_ID and API_HASH from https://my.telegram.org
# Get BOT_TOKEN from @BotFather on Telegram

COUNTBEANS_API_ID=
COUNTBEANS_API_HASH=
COUNTBEANS_BOT_TOKEN=

# Inside Docker Compose this is injected automatically (pointing at the `db`
# service); the Compose Postgres is not published to the host. Set this only if
# you run the bot or Alembic on the host against your own local Postgres.
COUNTBEANS_DATABASE_URL=postgresql+asyncpg://countbeans:countbeans@localhost:5432/countbeans
