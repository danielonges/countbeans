# Copy this file to .env and fill in your values.
# Get API_ID and API_HASH from https://my.telegram.org
# Get BOT_TOKEN from @BotFather on Telegram

COUNTBEANS_API_ID=
COUNTBEANS_API_HASH=
COUNTBEANS_BOT_TOKEN=

# Set automatically by Docker Compose — only needed if running the bot locally
# (outside Docker) against a local Postgres instance
COUNTBEANS_DATABASE_URL=postgresql+asyncpg://countbeans:countbeans@localhost:5432/countbeans
