# Copy this file to .env and fill in your values.
# Get BOT_TOKEN from @BotFather on Telegram

COUNTBEANS_BOT_TOKEN=

# --- Database credentials (Docker Compose) ---
# compose.yml assembles COUNTBEANS_DATABASE_URL from the Postgres vars below, so
# you normally don't set the DSN directly. The dev defaults work out of the box.
# For a REAL deployment, override these with strong credentials here (or let your
# platform inject COUNTBEANS_DATABASE_URL instead) — never ship the defaults.
# POSTGRES_USER=countbeans
# POSTGRES_PASSWORD=countbeans
# POSTGRES_DB=countbeans

# --- Connection-pool resilience (optional; sane defaults shown) ---
# Guards the always-on poller against stale pooled connections. Defaults are
# fine for most deploys; tune only if your provider needs it.
# COUNTBEANS_DB_POOL_PRE_PING=true
# COUNTBEANS_DB_POOL_RECYCLE_SECONDS=1800
