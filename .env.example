# Copy this file to .env and fill in your values.
# Get API_ID and API_HASH from https://my.telegram.org
# Get BOT_TOKEN from @BotFather on Telegram

COUNTBEANS_API_ID=
COUNTBEANS_API_HASH=
COUNTBEANS_BOT_TOKEN=

# Inside Docker Compose this is injected automatically (pointing at the `db`
# service). Set it here only for host-side tooling — running the bot or Alembic
# outside Docker against the Compose Postgres, which is published on host 5433.
COUNTBEANS_DATABASE_URL=postgresql+asyncpg://countbeans:countbeans@localhost:5433/countbeans
